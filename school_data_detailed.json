        st.divider()
        
        # 终点选择
        st.markdown("##### 终点")
        end_building = st.selectbox("建筑", buildings, key="end_building")
        end_levels = get_level_list(school_data, end_building)
        end_level = st.selectbox("楼层", end_levels, key="end_level")
