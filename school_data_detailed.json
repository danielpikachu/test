    try:
        # 优先从文件加载（核心修改：文件名改为school_data_detailed.json）
        with open(file_path, 'r', encoding='utf-8') as f:
            data = json.load(f)
        
        # 兼容检查：确保gate存在
        if 'gate' not in data:
            # 自动生成基础gate数据（备用）
            data['gate'] = {
                "levels": [
                    {
                        "name": "level1",
                        "z": -3,
                        "floorPlane": {
                            "minX": -40,
                            "maxX": -20,
                            "minY": -40,
                            "maxY": -20
                        },
                        "classrooms": [
                            {"name": "Main Gate", "coordinates": [-30, -30, -3], "size": [10, 10]}
                        ],
                        "corridors": [
                            {
                                "name": "gateToA",
                                "type": "external",
                                "style": {"color": "brown", "lineType": "dashed"},
                                "points": [[-30, -30, -3], [22, 18, -3]]
                            },
                            {
                                "name": "gateToB",
                                "type": "external",
                                "style": {"color": "brown", "lineType": "dashed"},
                                "points": [[-30, -30, -3], [22, -30, -3]]
                            },
                            {
                                "name": "gateToC",
                                "type": "external",
                                "style": {"color": "brown", "lineType": "dashed"},
                                "points": [[-30, -30, -3], [66, 26, -3]]
                            }
                        ],
                        "stairs": [{"name": "GateStairs", "coordinates": [-30, -30, -3]}]
                    }
                ],
                "connections": [
                    {"from": ["gateToA", "level1"], "to": ["ENTRANCE", "level1"]},
                    {"from": ["gateToB", "level1"], "to": ["connectToBuildingAAndC", "level1"]},
                    {"from": ["gateToC", "level1"], "to": ["SCHOOL CLINIC", "level1"]}
                ]
