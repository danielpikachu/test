        end_classroom = st.selectbox("教室/地点", end_classrooms, key="end_classroom")
        
        st.divider()
        
        # 按钮
        col_btn1, col_btn2 = st.columns(2)
        with col_btn1:
            if st.button("🔍 查找路径", use_container_width=True):
                path, message, details, display_options = navigate(
                    graph,
                    start_building,
                    start_classroom,
                    start_level,
                    end_building,
                    end_classroom,
                    end_level
                )
                st.session_state['current_path'] = path
                st.session_state['path_message'] = message
                st.session_state['path_details'] = details
                if display_options:
                    st.session_state['display_options'] = display_options
        
        with col_btn2:
            if st.button("🔄 重置视图", use_container_width=True):
                reset_app_state()
                st.rerun()
        
        # 返回欢迎页
        if st.button("🚪 返回首页", use_container_width=True, type="secondary"):
            reset_app_state()
            st.session_state['page'] = 'welcome'
            st.rerun()
        
        st.markdown('</div>', unsafe_allow_html=True)
        
        # 路径信息
        if 'path_message' in st.session_state and st.session_state['path_message']:
            st.markdown('<div class="nav-card">', unsafe_allow_html=True)
            st.markdown("#### 📊 路径信息")
            if st.session_state['current_path']:
                st.success(st.session_state['path_message'])
                st.markdown("##### 🛤️ 路径详情")
                st.info(st.session_state['path_details'])
            else:
                st.error(st.session_state['path_message'])
            st.markdown('</div>', unsafe_allow_html=True)
    
    with col2:
        st.markdown("#### 🗺️ 3D校园地图")
        try:
            fig, ax = plot_3d_map(school_data, st.session_state['display_options'])
            st.pyplot(fig, use_container_width=True)
        except Exception as e:
            st.error(f"绘制地图失败: {str(e)}")
    
    # 作者标签
    st.markdown('<div class="author-tag">SCIS Campus Navigation System v2.0</div>', unsafe_allow_html=True)

