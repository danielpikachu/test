# --------------------------
# 3D地图绘制
# --------------------------
def plot_3d_map(school_data, display_options=None):
    """绘制3D校园地图"""
    fig = plt.figure(figsize=(35, 30))
    ax = fig.add_subplot(111, projection='3d')

    # 默认显示配置
    if display_options is None:
        display_options = {
            'start_level': None,
            'end_level': None,
            'path_stairs': set(),
            'show_all': True,
            'path': [],
            'start_building': None,
            'end_building': None
        }
    
    show_all = display_options['show_all']
    start_level = display_options['start_level']
    end_level = display_options['end_level']
    start_building = display_options['start_building']
    end_building = display_options['end_building']
    path = display_options['path']
    
    # 建筑标签位置缓存
    building_label_positions = {}
    
    # 遍历所有建筑
    building_mapping = {
        'buildingA': 'A',
        'buildingB': 'B',
        'buildingC': 'C',
        'gate': 'Gate'
    }
    
    for building_key, building_data in school_data.items():
        building_name = building_mapping.get(building_key, building_key)
        
        # 遍历建筑的所有楼层
        for level in building_data['levels']:
            level_name = level['name']
            z = level['z']
            
            # 控制楼层显示
            if not show_all:
                # 只显示起点/终点楼层
                if (start_building == building_name and level_name != start_level) and \
                   (end_building == building_name and level_name != end_level):
                    continue
            
            # 绘制楼层平面
            floor = level['floorPlane']
            x = [floor['minX'], floor['maxX'], floor['maxX'], floor['minX'], floor['minX']]
            y = [floor['minY'], floor['minY'], floor['maxY'], floor['maxY'], floor['minY']]
            z_floor = [z] * 5
            ax.plot3D(x, y, z_floor, color=COLORS['floor_z'].get(z, 'gray'), alpha=0.3)
            
            # 记录建筑标签位置（取第一个楼层的中心）
            if building_name not in building_label_positions:
                center_x = (floor['minX'] + floor['maxX']) / 2
                center_y = (floor['minY'] + floor['maxY']) / 2
                building_label_positions[building_name] = (center_x, center_y, z + 1)
            
            # 绘制教室
            for classroom in level.get('classrooms', []):
                cx, cy, cz = classroom['coordinates']
                w, h = classroom['size']
                
                # 绘制教室立方体
                x_c = [cx, cx+w, cx+w, cx, cx]
                y_c = [cy, cy, cy+h, cy+h, cy]
                z_c = [cz] * 5
                ax.plot3D(x_c, y_c, z_c, color=COLORS['building'][building_name], alpha=0.7)
                ax.text(cx + w/2, cy + h/2, cz, classroom['name'], 
                        color=COLORS['classroom_label'], fontsize=8, ha='center')
            
            # 绘制走廊
            for corridor in level.get('corridors', []):
                points = corridor['points']
                x_corr = [p[0] for p in points]
                y_corr = [p[1] for p in points]
                z_corr = [p[2] for p in points]
                
                # 走廊样式
                corr_color = COLORS['corridor_line'].get(building_name, 'gray')
                if corridor.get('type') == 'external':
                    linestyle = '--' if corridor.get('style', {}).get('lineType') == 'dashed' else '-'
                    color = corridor.get('style', {}).get('color', corr_color)
                else:
                    linestyle = '-'
                    color = corr_color
                
                ax.plot3D(x_corr, y_corr, z_corr, color=color, linestyle=linestyle, linewidth=2)
                
                # 绘制走廊节点
                for i, (x, y, z) in enumerate(points):
                    ax.scatter(x, y, z, color=COLORS['corridor_node'], s=20)
                    if corridor.get('name') and i == 0:
                        ax.text(x, y, z, corridor['name'], 
                                color=COLORS['corridor_label'], fontsize=7, ha='center')
            
            # 绘制楼梯
            for stair in level.get('stairs', []):
                sx, sy, sz = stair['coordinates']
                ax.scatter(sx, sy, sz, color=COLORS['stair'].get(stair['name'], 'red'), s=50, marker='^')
                ax.text(sx, sy, sz + 0.5, stair['name'], 
                        color=COLORS['stair_label'], fontsize=9, ha='center')
    
    # 绘制建筑标签
    for building_name, (x, y, z) in building_label_positions.items():
        bbox_props = dict(boxstyle="round,pad=0.3", edgecolor="black", 
                         facecolor=COLORS['building'][building_name], alpha=0.7)
        ax.text(x, y, z, f"Building {building_name}", 
                color=COLORS['building_label'][building_name], fontsize=12, 
                ha='center', va='center', bbox=bbox_props, weight='bold')
    
    # 绘制导航路径
    if path and not show_all:
        try:
            x_path = []
            y_path = []
            z_path = []
            labels = []
            
            for node_id in path:
                if node_id in graph.nodes:
                    coords = graph.nodes[node_id]['coordinates']
                    x_path.append(coords[0])
                    y_path.append(coords[1])
                    z_path.append(coords[2])
                    
                    # 节点标签
                    node_type = graph.nodes[node_id]['type']
                    if node_type == 'classroom':
                        labels.append(graph.nodes[node_id]['name'])
                    elif node_type == 'stair':
                        labels.append(graph.nodes[node_id]['name'])
                    else:
                        labels.append("")
            
            # 绘制路径线
            ax.plot3D(x_path, y_path, z_path, color=COLORS['path'], linewidth=3, marker='o', markersize=5)
            
            # 起点/终点标记
            if x_path:
                # 起点
                ax.scatter(x_path[0], y_path[0], z_path[0], 
                          color=COLORS['start_marker'], s=100, marker='*')
                ax.text(x_path[0], y_path[0], z_path[0] + 1, 
                        f"Start: {labels[0] if labels[0] else 'Gate'}", 
                        color=COLORS['start_label'], fontsize=10, ha='center')
                
                # 终点
                ax.scatter(x_path[-1], y_path[-1], z_path[-1], 
                          color=COLORS['end_marker'], s=100, marker='*')
                ax.text(x_path[-1], y_path[-1], z_path[-1] + 1, 
                        f"End: {labels[-1] if labels[-1] else 'Gate'}", 
                        color=COLORS['end_label'], fontsize=10, ha='center')
        except Exception as e:
            st.warning(f"绘制导航路径失败: {str(e)}")
    
    # 设置坐标轴标签
    ax.set_xlabel('X Coordinate', fontsize=18, weight='bold')
    ax.set_ylabel('Y Coordinate', fontsize=18, weight='bold')
    ax.set_zlabel('Z Height (Floor)', fontsize=18, weight='bold')
    ax.set_title('SCIS Campus 3D Navigation Map (Gate/A/B/C)', fontsize=24, weight='bold', pad=20)
    
    # 调整视角
    ax.view_init(elev=20, azim=45)
    ax.grid(True, alpha=0.3, linewidth=2)
    
    return fig, ax

# --------------------------
# 图结构（导航核心）
# --------------------------
class Graph:
    def __init__(self):
        self.nodes = {}       # 节点字典: {node_id: {'building': '', 'type': '', 'name': '', 'level': '', 'coordinates': [], 'neighbors': {}}}
        self.node_id_map = {} # 映射: {(building_key, type, name, level): node_id}

    def add_node(self, building_key, node_type, name, level, coordinates):
        """添加节点"""
        building_name = {
            'buildingA': 'A',
            'buildingB': 'B',
            'buildingC': 'C',
            'gate': 'Gate'
        }.get(building_key, building_key)
        
        # 生成节点ID
        if node_type == 'corridor':
            node_id = f"{building_name}-corr-{name}@{level}"
        elif node_type == 'stair':
            node_id = f"{building_name}-stair-{name}@{level}"
        elif node_type == 'classroom':
            node_id = f"{building_name}-class-{name}@{level}"
        else:
            node_id = f"{building_name}-{node_type}-{name}@{level}"
        
        # 存储节点信息
        self.nodes[node_id] = {
            'building': building_name,
            'building_key': building_key,
            'type': node_type,
            'name': name,
            'level': level,
            'coordinates': coordinates,
            'neighbors': {}
        }
        
        # 建立映射
        map_key = (building_key, node_type, name, level)
        self.node_id_map[map_key] = node_id
        
        return node_id

    def add_edge(self, node1_id, node2_id, weight):
        """添加边（双向）"""
        if node1_id in self.nodes and node2_id in self.nodes:
            self.nodes[node1_id]['neighbors'][node2_id] = weight
            self.nodes[node2_id]['neighbors'][node1_id] = weight

def euclidean_distance(coords1, coords2):
    """计算欧几里得距离"""
    return np.sqrt(sum((a - b) ** 2 for a, b in zip(coords1, coords2)))

def build_navigation_graph(school_data):
    """构建导航图（支持Gate与A/B/C直接连接）"""
    graph = Graph()
    
    # 1. 添加所有节点
    for building_key, building_data in school_data.items():
        # 遍历楼层
        for level in building_data['levels']:
            level_name = level['name']
            
            # 添加教室节点
            for classroom in level.get('classrooms', []):
                graph.add_node(
                    building_key,
                    'classroom',
                    classroom['name'],
                    level_name,
                    classroom['coordinates']
                )
            
            # 添加楼梯节点
            for stair in level.get('stairs', []):
                graph.add_node(
                    building_key,
                    'stair',
                    stair['name'],
                    level_name,
                    stair['coordinates']
                )
            
            # 添加走廊节点
            for corridor in level.get('corridors', []):
                corr_name = corridor.get('name', f"corr_{id(corridor)}")
                for i, point in enumerate(corridor['points']):
                    graph.add_node(
                        building_key,
                        'corridor',
                        f"{corr_name}-p{i}",
                        level_name,
                        point
                    )
    
    # 2. 添加内部边（同建筑/同楼层）
    for building_key, building_data in school_data.items():
        for level in building_data['levels']:
            level_name = level['name']
            
            # 2.1 走廊内部节点连接
            for corridor in level.get('corridors', []):
                corr_name = corridor.get('name', f"corr_{id(corridor)}")
                points = corridor['points']
                
                # 连接相邻的走廊点
                for i in range(len(points) - 1):
                    node1_id = graph.node_id_map.get((building_key, 'corridor', f"{corr_name}-p{i}", level_name))
                    node2_id = graph.node_id_map.get((building_key, 'corridor', f"{corr_name}-p{i+1}", level_name))
                    
                    if node1_id and node2_id:
                        distance = euclidean_distance(points[i], points[i+1])
                        graph.add_edge(node1_id, node2_id, distance)
            
            # 2.2 教室连接到最近的走廊节点
            for classroom in level.get('classrooms', []):
                class_node_id = graph.node_id_map.get((building_key, 'classroom', classroom['name'], level_name))
                if not class_node_id:
                    continue
                
                # 找到最近的走廊节点
                min_distance = float('inf')
                nearest_corr_node = None
                
                # 遍历所有同楼层的走廊节点
                for (bk, nt, nn, nl), node_id in graph.node_id_map.items():
                    if bk == building_key and nt == 'corridor' and nl == level_name:
                        corr_coords = graph.nodes[node_id]['coordinates']
                        distance = euclidean_distance(classroom['coordinates'], corr_coords)
                        if distance < min_distance:
                            min_distance = distance
                            nearest_corr_node = node_id
                
                if nearest_corr_node:
                    graph.add_edge(class_node_id, nearest_corr_node, min_distance)
            
            # 2.3 楼梯连接到最近的走廊节点
            for stair in level.get('stairs', []):
                stair_node_id = graph.node_id_map.get((building_key, 'stair', stair['name'], level_name))
                if not stair_node_id:
                    continue
                
                # 找到最近的走廊节点
                min_distance = float('inf')
                nearest_corr_node = None
                
                for (bk, nt, nn, nl), node_id in graph.node_id_map.items():
                    if bk == building_key and nt == 'corridor' and nl == level_name:
                        corr_coords = graph.nodes[node_id]['coordinates']
                        distance = euclidean_distance(stair['coordinates'], corr_coords)
                        if distance < min_distance:
                            min_distance = distance
                            nearest_corr_node = node_id
                
                if nearest_corr_node:
                    graph.add_edge(stair_node_id, nearest_corr_node, min_distance)
        
        # 2.4 建筑内部跨楼层连接（楼梯）
        for connection in building_data.get('connections', []):
            from_obj = connection['from']  # [name, level]
            to_obj = connection['to']      # [name, level]
            
            # 判断是楼梯还是走廊连接
            if from_obj[0] in ['Stairs1', 'Stairs2', 'Stairs3', 'Stairs4', 'Stairs5', 'StairsB1', 'StairsB2', 'GateStairs']:
                # 楼梯连接
                from_node_id = graph.node_id_map.get((building_key, 'stair', from_obj[0], from_obj[1]))
                to_node_id = graph.node_id_map.get((building_key, 'stair', to_obj[0], to_obj[1]))
            else:
                # 走廊连接
                from_node_id = graph.node_id_map.get((building_key, 'corridor', from_obj[0], from_obj[1]))
                to_node_id = graph.node_id_map.get((building_key, 'corridor', to_obj[0], to_obj[1]))
            
            if from_node_id and to_node_id:
                # 楼梯/走廊跨楼层距离（固定值）
                graph.add_edge(from_node_id, to_node_id, 5.0)
    
    # 3. 添加建筑间外部连接（核心：Gate与A/B/C直接连接）
    connect_level = 'level1'
    
    # 3.1 Gate ↔ A 直接连接
    gate_a_from = graph.node_id_map.get(('gate', 'corridor', 'gateToA-p0', connect_level))
    gate_a_to = graph.node_id_map.get(('buildingA', 'corridor', 'gateToA-p3', connect_level))
    if gate_a_from and gate_a_to:
        coords1 = graph.nodes[gate_a_from]['coordinates']
        coords2 = graph.nodes[gate_a_to]['coordinates']
        distance = euclidean_distance(coords1, coords2)
        graph.add_edge(gate_a_from, gate_a_to, distance)
    
    # 3.2 Gate ↔ B 直接连接
    gate_b_from = graph.node_id_map.get(('gate', 'corridor', 'gateToB-p0', connect_level))
    gate_b_to = graph.node_id_map.get(('buildingB', 'corridor', 'gateToB-p3', connect_level))
    if gate_b_from and gate_b_to:
        coords1 = graph.nodes[gate_b_from]['coordinates']
        coords2 = graph.nodes[gate_b_to]['coordinates']
        distance = euclidean_distance(coords1, coords2)
        graph.add_edge(gate_b_from, gate_b_to, distance)
    
    # 3.3 Gate ↔ C 直接连接
    gate_c_from = graph.node_id_map.get(('gate', 'corridor', 'gateToC-p0', connect_level))
    gate_c_to = graph.node_id_map.get(('buildingC', 'corridor', 'gateToC-p3', connect_level))
    if gate_c_from and gate_c_to:
        coords1 = graph.nodes[gate_c_from]['coordinates']
        coords2 = graph.nodes[gate_c_to]['coordinates']
        distance = euclidean_distance(coords1, coords2)
        graph.add_edge(gate_c_from, gate_c_to, distance)
    
    # 3.4 A ↔ B 原有连接
    a_b_from = graph.node_id_map.get(('buildingA', 'corridor', 'connectToBuildingB-p1', connect_level))
    a_b_to = graph.node_id_map.get(('buildingB', 'corridor', 'connectToBuildingAAndC-p1', connect_level))
    if a_b_from and a_b_to:
        coords1 = graph.nodes[a_b_from]['coordinates']
        coords2 = graph.nodes[a_b_to]['coordinates']
        distance = euclidean_distance(coords1, coords2)
        graph.add_edge(a_b_from, a_b_to, distance)
    
    # 3.5 B ↔ C 原有连接
    b_c_from = graph.node_id_map.get(('buildingB', 'corridor', 'connectToBuildingAAndC-p0', connect_level))
    b_c_to = graph.node_id_map.get(('buildingC', 'corridor', 'connectToBuildingB-p3', connect_level))
    if b_c_from and b_c_to:
        coords1 = graph.nodes[b_c_from]['coordinates']
        coords2 = graph.nodes[b_c_to]['coordinates']
        distance = euclidean_distance(coords1, coords2)
        graph.add_edge(b_c_from, b_c_to, distance)
    
    # 3.6 A ↔ C 原有连接（level1）
    a_c1_from = graph.node_id_map.get(('buildingA', 'corridor', 'connectToBuildingC-p3', connect_level))
    a_c1_to = graph.node_id_map.get(('buildingC', 'corridor', 'connectToBuildingA-p4', connect_level))
    if a_c1_from and a_c1_to:
        coords1 = graph.nodes[a_c1_from]['coordinates']
        coords2 = graph.nodes[a_c1_to]['coordinates']
        distance = euclidean_distance(coords1, coords2)
        graph.add_edge(a_c1_from, a_c1_to, distance)
    
    # 3.7 A ↔ C 原有连接（level3）
    a_c3_from = graph.node_id_map.get(('buildingA', 'corridor', 'connectToBuildingC-p3', 'level3'))
    a_c3_to = graph.node_id_map.get(('buildingC', 'corridor', 'connectToBuildingA-p3', 'level3'))
    if a_c3_from and a_c3_to:
        coords1 = graph.nodes[a_c3_from]['coordinates']
        coords2 = graph.nodes[a_c3_to]['coordinates']
        distance = euclidean_distance(coords1, coords2)
        graph.add_edge(a_c3_from, a_c3_to, distance)
    
    return graph

# --------------------------
# 最短路径算法（Dijkstra）
# --------------------------
def dijkstra(graph, start_node_id):
    """Dijkstra算法找最短路径"""
    # 初始化距离字典
    distances = {node: float('inf') for node in graph.nodes}
    distances[start_node_id] = 0
    
    # 前驱节点字典
    previous_nodes = {node: None for node in graph.nodes}
    
    # 未访问节点集合
    unvisited = set(graph.nodes.keys())
    
    while unvisited:
        # 找到当前距离最小的节点
        current_node = min(unvisited, key=lambda node: distances[node])
        
        # 如果距离是无穷大，说明无法到达
        if distances[current_node] == float('inf'):
            break
        
        # 遍历邻居节点
        for neighbor, weight in graph.nodes[current_node]['neighbors'].items():
            if neighbor in unvisited:
                new_distance = distances[current_node] + weight
                if new_distance < distances[neighbor]:
                    distances[neighbor] = new_distance
                    previous_nodes[neighbor] = current_node
        
        # 标记为已访问
        unvisited.remove(current_node)
    
    return distances, previous_nodes

def reconstruct_path(previous_nodes, end_node_id):
    """重构路径"""
    path = []
    current_node = end_node_id
    
    while current_node is not None:
        path.insert(0, current_node)
        current_node = previous_nodes[current_node]
    
    # 路径长度至少为2才有效
    return path if len(path) > 1 else None

def navigate(graph, start_building, start_classroom, start_level, end_building, end_classroom, end_level):
    """导航主函数"""
    # 验证建筑
    valid_buildings = ['A', 'B', 'C', 'Gate']
    if start_building not in valid_buildings or end_building not in valid_buildings:
        return None, f"无效建筑！仅支持: {', '.join(valid_buildings)}", None, None
    
    # 映射建筑名称到key
    building_key_map = {
        'A': 'buildingA',
        'B': 'buildingB',
        'C': 'buildingC',
        'Gate': 'gate'
    }
    
    # 找到起点节点
    start_key = building_key_map[start_building]
    start_node_id = graph.node_id_map.get((start_key, 'classroom', start_classroom, start_level))
    
    # 找到终点节点
    end_key = building_key_map[end_building]
    end_node_id = graph.node_id_map.get((end_key, 'classroom', end_classroom, end_level))
    
    # 验证节点是否存在
    if not start_node_id:
        return None, f"起点不存在: {start_building}楼 {start_level} 层 {start_classroom}", None, None
    if not end_node_id:
        return None, f"终点不存在: {end_building}楼 {end_level} 层 {end_classroom}", None, None
    
    # 计算最短路径
    distances, previous_nodes = dijkstra(graph, start_node_id)
    
    # 重构路径
    path = reconstruct_path(previous_nodes, end_node_id)
    if not path:
        return None, "无法找到路径！", None, None
    
    # 计算总距离
    total_distance = distances[end_node_id]
    
    # 生成简化路径描述
    simplified_path = []
    path_stairs = set()
    
    for node_id in path:
        node = graph.nodes[node_id]
        building = node['building']
        node_type = node['type']
        name = node['name']
        level = node['level']
        
        if node_type == 'stair':
            path_stairs.add((building, name, level))
            simplified_path.append(f"{building}楼 {level} 层 {name}")
        elif node_type == 'classroom':
            simplified_path.append(f"{building}楼 {level} 层 {name}")
        elif node_type == 'corridor' and 'connectTo' in name:
            # 外部走廊
            simplified_path.append(f"从{building}楼前往{name.replace('connectToBuilding', '')}楼")
    
    # 生成显示配置
    display_options = {
        'start_level': start_level,
        'end_level': end_level,
        'path_stairs': path_stairs,
        'show_all': False,
        'path': path,
        'start_building': start_building,
        'end_building': end_building
    }
    
    return path, f"最短路径距离: {total_distance:.2f} 单位", " → ".join(simplified_path), display_options

# --------------------------
# 辅助函数：获取建筑/楼层/教室列表
# --------------------------
def get_building_list(school_data):
    """获取建筑列表"""
    buildings = []
    if 'buildingA' in school_data:
        buildings.append('A')
    if 'buildingB' in school_data:
        buildings.append('B')
    if 'buildingC' in school_data:
        buildings.append('C')
    if 'gate' in school_data:
        buildings.append('Gate')
    return buildings

def get_level_list(school_data, building_name):
    """获取指定建筑的楼层列表"""
    building_key_map = {
        'A': 'buildingA',
        'B': 'buildingB',
        'C': 'buildingC',
        'Gate': 'gate'
    }
    building_key = building_key_map.get(building_name)
    if not building_key or building_key not in school_data:
        return []
    
    return [level['name'] for level in school_data[building_key]['levels']]

def get_classroom_list(school_data, building_name, level_name):
    """获取指定建筑/楼层的教室列表"""
    building_key_map = {
        'A': 'buildingA',
        'B': 'buildingB',
        'C': 'buildingC',
        'Gate': 'gate'
    }
    building_key = building_key_map.get(building_name)
    if not building_key or building_key not in school_data:
        return []
    
    # 找到对应楼层
    for level in school_data[building_key]['levels']:
        if level['name'] == level_name:
            return [classroom['name'] for classroom in level.get('classrooms', [])]
    
    return []

