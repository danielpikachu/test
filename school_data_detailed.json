    st.subheader("🏫 SCIS 校园3D导航系统 (Gate/A/B/C楼)", divider='blue')
    
    # 布局
    col1, col2 = st.columns([1, 3])
    
    with col1:
        st.markdown('<div class="nav-card">', unsafe_allow_html=True)
        st.markdown("#### 📍 选择导航点")
        
        # 获取建筑列表
        buildings = get_building_list(school_data)
        
        # 起点选择
        st.markdown("##### 起点")
        start_building = st.selectbox("建筑", buildings, key="start_building")
        start_levels = get_level_list(school_data, start_building)
        start_level = st.selectbox("楼层", start_levels, key="start_level")
